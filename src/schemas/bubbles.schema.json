{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bubbles",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "job_id", "language", "offers", "expects", "constraints"],
  "properties": {
    "version": {"type": "string"},
    "job_id": {"type": ["string", "null"]},
    "language": {"type": ["string", "null"]},
    "offers": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": {
          "text": {"type": "string", "minLength": 4, "maxLength": 64}
        }
      }
    },
    "expects": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": {
          "text": {"type": "string", "minLength": 4, "maxLength": 64}
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_items", "max_items", "max_text_len"],
      "properties": {
        "min_items": {"type": "integer"},
        "max_items": {"type": "integer"},
        "max_text_len": {"type": "integer"}
      }
    }
  }
}
