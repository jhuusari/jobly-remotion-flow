{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Partner Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["job_id", "video_url", "thumbnail_url", "created_date", "source_url"],
  "properties": {
    "job_id": {"type": "string"},
    "video_url": {"type": "string"},
    "thumbnail_url": {"type": "string"},
    "created_date": {"type": "string", "format": "date-time"},
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "id": {"type": "string"}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currency": {"type": "string", "minLength": 3, "maxLength": 3},
        "min": {"type": "number"},
        "max": {"type": "number"}
      }
    },
    "source_url": {"type": "string", "format": "uri"},
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "raw_html_path": {"type": "string"},
        "extracted_path": {"type": "string"},
        "bubbles_path": {"type": "string"}
      }
    }
  }
}
